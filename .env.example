# Phora environment template. Copy to .env.local (gitignored) and fill in.
# Never commit real values. NEXT_PUBLIC_* are exposed to the browser by design.

# --- World ID (uniqueness) ---
NEXT_PUBLIC_WORLD_APP_ID=app_11e8bf4c2d9b3a8ef28e0c805e08c14c
NEXT_PUBLIC_WORLD_RP_ID=rp_4571868f9e535bb7
WORLD_RP_SIGNING_KEY=                 # secret; RP signature key (signer 0xba569038966Ae11a3B0d176D80ffe34f4D36a21E)

# --- Dynamic (auth, embedded wallets, agent server wallet) ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_API_TOKEN=                    # secret; server-wallet auth (agent slice)
AGENT_WALLET_PASSWORD=                # secret; encrypts the server-wallet key share

# --- Allium (rendering) ---
ALLIUM_API_KEY=                       # secret; server-side only

# --- RPC endpoints ---
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
WORLDCHAIN_RPC_URL=                   # agent slice only (World Chain mainnet, eip155:480)

# --- Database ---
DATABASE_URL=                         # Postgres (Neon / Vercel Postgres)
